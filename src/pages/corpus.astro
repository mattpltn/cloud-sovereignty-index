---
import '../styles/global.css';

let corpus: unknown[] = [];
try {
  const res = await fetch('http://localhost:8787/api/corpus');
  if (res.ok) corpus = await res.json() as unknown[];
} catch { /* Workers not running */ }
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Public Corpus — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-4">
    <a href="/" class="font-semibold text-lg tracking-tight">Cloud Sovereignty Index</a>
  </header>
  <main class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold mb-4">Public corpus</h1>
    <p class="text-sm text-gray-600 mb-8">
      Anonymized assessments from participants who opted in to public sharing.
    </p>
    {corpus.length === 0 ? (
      <p class="text-gray-400 text-sm">No public entries yet.</p>
    ) : (
      <div class="text-sm text-gray-600">{corpus.length} entries in the corpus.</div>
    )}
  </main>
</body>
</html>
