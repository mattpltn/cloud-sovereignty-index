---
import '../../styles/global.css';
import countriesJson from '../../../data/countries.json';
import criteriaJson from '../../../data/criteria.json';
import ImportAssessment from '../../components/ImportAssessment';
import type { CriteriaFile } from '../../../shared/src/schema';

const criteria = criteriaJson as unknown as CriteriaFile;

const euCodes = new Set([
  ...countriesJson.EU.map(c => c.code),
  ...countriesJson.EEA_non_EU.map(c => c.code),
]);

const allCountries = [
  ...countriesJson.EU,
  ...countriesJson.EEA_non_EU,
  ...countriesJson.non_EU,
].sort((a, b) => a.name.localeCompare(b.name));

// Collect AC questions for the customer-selection panel
const acQuestions: Array<{ id: string; title: string; objective_id: string; objective_title: string; text: string }> = [];
for (const obj of criteria.objectives) {
  for (const q of obj.questions) {
    if (q.c3a_tier === 'additional' && q.type === 'single') {
      acQuestions.push({ id: q.id, title: q.title, objective_id: obj.id, objective_title: obj.title, text: q.text });
    }
  }
}

// Group ACs by objective for display
const acByObjective = new Map<string, { title: string; questions: typeof acQuestions }>();
for (const ac of acQuestions) {
  if (!acByObjective.has(ac.objective_id)) {
    acByObjective.set(ac.objective_id, { title: ac.objective_title, questions: [] });
  }
  acByObjective.get(ac.objective_id)!.questions.push(ac);
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Setup Assessment — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-semibold text-lg tracking-tight">Cloud Sovereignty Index</a>
  </header>

  <main class="max-w-xl mx-auto px-6 py-12">
    <h1 class="text-2xl font-bold mb-2">Configure your assessment</h1>
    <p class="text-gray-600 text-sm mb-8">
      Select your country and which framework(s) to assess against. Each selected framework is evaluated independently.
    </p>

    <form id="setup-form" class="space-y-6">
      <input type="hidden" id="variant-input" name="variant" value="EU-CSF" />

      <div>
        <label class="block text-sm font-medium mb-2">Country</label>
        <select name="national_country" id="country-select" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
          <option value="">— Select your country —</option>
          {allCountries.map(c => (
            <option value={c.code}>{c.name}</option>
          ))}
        </select>
        <p id="country-error" class="text-red-600 text-xs mt-1 hidden">Select a country.</p>
        <p id="variant-badge" class="text-xs mt-1.5 text-gray-400 hidden"></p>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Organisation name</label>
        <input type="text" name="company_name" id="company-name" placeholder="Acme Corp"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
        <p id="company-error" class="text-red-600 text-xs mt-1 hidden">Enter your organisation name.</p>
        <p class="text-xs text-gray-400 mt-1">Not indexed. Stored only in your assessment record.</p>
      </div>

      <!-- Framework selection -->
      <div>
        <label class="block text-sm font-medium mb-3">Framework(s) to assess against</label>
        <p class="text-xs text-gray-500 mb-3">Results for each selected framework are reported independently — no combined score.</p>
        <div class="space-y-3">
          <label class="flex items-start gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:border-gray-400 transition">
            <input type="checkbox" name="framework" value="eu_csf" id="fw-eu-csf"
              class="mt-0.5 h-4 w-4 rounded border-gray-300" />
            <div>
              <span class="text-sm font-medium">EU Cloud Sovereignty Framework (EU-CSF)</span>
              <p class="text-xs text-gray-500 mt-0.5">EU-CSF v1.2.1 — European Commission. Output: SEAL 0–4 per objective. For EU procurement compliance.</p>
            </div>
          </label>
          <label class="flex items-start gap-3 p-3 border border-gray-200 rounded-lg cursor-pointer hover:border-gray-400 transition">
            <input type="checkbox" name="framework" value="c3a" id="fw-c3a"
              class="mt-0.5 h-4 w-4 rounded border-gray-300" />
            <div>
              <span class="text-sm font-medium">C3A — BSI Criteria enabling Cloud Computing Autonomy</span>
              <p class="text-xs text-gray-500 mt-0.5">C3A v1.0 — BSI. Output: pass/fail per criterion, % met. SOV-1 through SOV-6 only. Binary — no partial credit.</p>
            </div>
          </label>
          <label class="flex items-start gap-3 p-3 border border-blue-200 bg-blue-50 rounded-lg cursor-pointer hover:border-blue-400 transition">
            <input type="checkbox" name="framework" value="csi_composite" id="fw-csi" checked
              class="mt-0.5 h-4 w-4 rounded border-gray-300" />
            <div>
              <span class="text-sm font-medium">CSI Composite <span class="text-xs text-blue-600 font-normal ml-1">Recommended for global users</span></span>
              <p class="text-xs text-gray-500 mt-0.5">CSI editorial framework — blends EU-CSF and C3A with adaptations for global use. Output: CSL 0–4 (SEAL for EU/EEA).</p>
            </div>
          </label>
        </div>
        <p id="framework-error" class="text-red-600 text-xs mt-2 hidden">Select at least one framework.</p>
      </div>

      <!-- C3A Additional Criteria selection (shown only when C3A is ticked) -->
      <div id="ac-panel" class="hidden">
        <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
          <h3 class="text-sm font-medium mb-1">C3A Additional Criteria (AC)</h3>
          <p class="text-xs text-gray-500 mb-3">
            Per C3A §1.4, the customer selects which Additional Criteria apply. The AC % is calculated
            only over the criteria you include here.
            There are <strong>{acQuestions.length} Additional Criteria</strong> across {acByObjective.size} objectives
            (vs {criteria.objectives.reduce((n, o) => n + o.questions.filter(q => q.c3a_tier === 'base' && q.applies_to_c3a).length, 0)} base criteria).
          </p>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="ac-select-all" class="h-4 w-4 rounded border-gray-300" />
            <div>
              <span class="text-sm font-medium text-gray-800">Include all {acQuestions.length} Additional Criteria</span>
              <p class="text-xs text-gray-500 mt-0.5">Uncheck to exclude ACs from your result (AC % will not be reported).</p>
            </div>
          </label>
          <!-- Hidden inputs populated by JS when checkbox is ticked -->
          <div id="ac-hidden-inputs"></div>
        </div>
      </div>

      <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA'} data-theme="light" data-callback="onTurnstileSolved"></div>

      <button type="submit" id="submit-btn"
        class="w-full bg-gray-900 text-white rounded-lg px-4 py-2.5 text-sm font-medium hover:bg-gray-700 transition">
        Start assessment
      </button>

      <p id="error-msg" class="text-red-600 text-sm hidden"></p>
    </form>

    <div class="relative flex items-center py-6">
      <div class="flex-grow border-t border-gray-200"></div>
      <span class="mx-4 text-xs text-gray-400">or import existing answers</span>
      <div class="flex-grow border-t border-gray-200"></div>
    </div>

    <div id="import">
      <ImportAssessment
        client:load
        criteria={criteria}
        countries={countriesJson}
        defaultVariant="EU-CSF"
      />
    </div>
  </main>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script is:inline>
    window.__turnstileToken = '';
    function onTurnstileSolved(token) { window.__turnstileToken = token; }
  </script>
  <script define:vars={{ euCodes: [...euCodes], allAcIds: acQuestions.map(q => q.id) }}>
    const euSet = new Set(euCodes);
    const select = document.getElementById('country-select');
    const variantInput = document.getElementById('variant-input');
    const badge = document.getElementById('variant-badge');
    const c3aCheckbox = document.getElementById('fw-c3a');
    const acPanel = document.getElementById('ac-panel');
    const acSelectAll = document.getElementById('ac-select-all');
    const acHiddenInputs = document.getElementById('ac-hidden-inputs');
    const frameworkError = document.getElementById('framework-error');

    select.addEventListener('change', () => {
      const code = select.value;
      if (!code) {
        variantInput.value = 'EU-CSF';
        badge.classList.add('hidden');
        return;
      }
      const isEU = euSet.has(code);
      variantInput.value = isEU ? 'EU-CSF' : 'Generalized';
      badge.textContent = isEU
        ? '✓ EU/EEA country — EU Cloud Sovereignty Framework criteria apply'
        : '✓ Non-EU country — Generalized criteria with local framework references';
      badge.className = `text-xs mt-1.5 ${isEU ? 'text-blue-600' : 'text-green-700'}`;
    });

    // Show/hide AC panel when C3A is ticked
    c3aCheckbox.addEventListener('change', () => {
      acPanel.classList.toggle('hidden', !c3aCheckbox.checked);
    });

    // "Include all ACs" checkbox: populate/clear hidden inputs
    acSelectAll.addEventListener('change', () => {
      acHiddenInputs.innerHTML = '';
      if (acSelectAll.checked) {
        allAcIds.forEach(id => {
          const inp = document.createElement('input');
          inp.type = 'hidden';
          inp.name = 'ac_criterion';
          inp.value = id;
          acHiddenInputs.appendChild(inp);
        });
      }
    });

    const form = document.getElementById('setup-form');
    const errorMsg = document.getElementById('error-msg');
    const countryError = document.getElementById('country-error');
    const companyError = document.getElementById('company-error');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      frameworkError.classList.add('hidden');
      countryError.classList.add('hidden');
      companyError.classList.add('hidden');

      const fd = new FormData(form);
      const variant = fd.get('variant');
      const national_country = fd.get('national_country') || undefined;
      const company_name = (fd.get('company_name') || '').trim() || undefined;
      const turnstile_token = fd.get('cf-turnstile-response') ?? 'test-token';

      let hasError = false;
      if (!national_country) {
        countryError.classList.remove('hidden');
        hasError = true;
      }
      if (!company_name) {
        companyError.classList.remove('hidden');
        hasError = true;
      }

      const selected_frameworks = fd.getAll('framework');
      if (selected_frameworks.length === 0) {
        frameworkError.classList.remove('hidden');
        hasError = true;
      }
      if (hasError) return;

      const customer_selected_ac_ids = fd.getAll('ac_criterion');

      try {
        const res = await fetch('/api/assessments', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            variant, national_country, company_name, turnstile_token,
            service_models: ['all'],
            user_role: 'customer',
            selected_frameworks,
            customer_selected_ac_ids,
          }),
        });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(JSON.stringify(err.error));
        }
        const data = await res.json();
        localStorage.setItem(`csi:${data.id}`, JSON.stringify({ answers: {} }));
        window.location.href = `/assess/${data.id}/created`;
      } catch (err) {
        errorMsg.textContent = String(err);
        errorMsg.classList.remove('hidden');
      }
    });
  </script>
</body>
</html>
