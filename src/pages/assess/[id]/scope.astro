---
import '../../../styles/global.css';
import { ScopingFlow } from '../../../components/ScopingFlow';
export const prerender = false;

const { id } = Astro.params;

// Fetch assessment to check framework selection
let selectedFrameworks: string[] = [];
try {
  const apiBase = new URL('/api', Astro.request.url).toString();
  const res = await fetch(`${apiBase}/assessments/${id}`);
  if (res.ok) {
    const data = await res.json() as { selected_frameworks?: string };
    if (data.selected_frameworks) selectedFrameworks = JSON.parse(data.selected_frameworks);
  }
} catch {
  // Workers not available — proceed without redirect guard
}

// Only CSI/LMIC assessments need the scoping step
if (selectedFrameworks.length > 0 && !selectedFrameworks.includes('csi_composite')) {
  return Astro.redirect(`/assess/${id}/SOV-1`);
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Infrastructure control profile — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-4">
    <a href="/" class="font-semibold text-lg tracking-tight">Cloud Sovereignty Index</a>
  </header>

  <main class="max-w-2xl mx-auto px-6 py-10">
    <div class="mb-8">
      <h1 class="text-2xl font-bold mb-2">Infrastructure control profile</h1>
      <p class="text-gray-600 text-sm">
        Your answers here filter the questionnaire to questions relevant to your configuration
        and drive the posture report on the results page.
      </p>
    </div>

    <ScopingFlow client:load assessmentId={id!} />
  </main>
</body>
</html>
