---
import '../../../styles/global.css';
import ScoreHero from '../../../components/ScoreHero';
import ExportAnswers from '../../../components/ExportAnswers';
import ObjectiveAccordion from '../../../components/ObjectiveAccordion';
import PdfExportButton from '../../../components/PdfExportButton';
import criteriaJson from '../../../../data/criteria.json';
import countriesJson from '../../../../data/countries.json';
import type { CriteriaFile } from '../../../../shared/src/schema';
export const prerender = false;

const criteria = criteriaJson as unknown as CriteriaFile;

const { id } = Astro.params;

let record: Record<string, unknown> | null = null;
let result: Record<string, unknown> | null = null;

const apiBase = new URL('/api', Astro.request.url).toString();
try {
  const res = await fetch(`${apiBase}/assessments/${id}`);
  if (res.ok) {
    record = await res.json() as Record<string, unknown>;
    if (record.computed_score) {
      result = typeof record.computed_score === 'string'
        ? JSON.parse(record.computed_score as string)
        : record.computed_score as Record<string, unknown>;
    }
  }
} catch {
  // Workers not available
}

const score = (result?.overall_score as number) ?? 0;
const sealLevel = (result?.seal_level as number) ?? 0;
const variant = (record?.variant as string) ?? 'EU-CSF';
const instrumentVersion = (record?.instrument_version as string) ?? '1.0';
const c5Supplementary = (result?.c5_supplementary as import('../../../../shared/src/types').C5SupplementaryResult | undefined);
const objectives = (result?.objectives as Array<Record<string, unknown>>) ?? [];
const gapReport = (result?.gap_report as Array<Record<string, unknown>>) ?? [];
const companyName = (record?.company_name as string | undefined) || undefined;

interface HistoryEntry { id: number; submitted_at: string; seal_level: number; overall_score: number }
const history = (record?.history as HistoryEntry[]) ?? [];
const countryCode = (record?.national_country as string | undefined) || undefined;

// Look up country object for placeholder resolution
const allCountries = [...countriesJson.EU, ...countriesJson.EEA_non_EU, ...countriesJson.non_EU];
const country = countryCode ? allCountries.find(c => c.code === countryCode) : undefined;

// ── Analysis: SEAL explanation ───────────────────────────────────────────────
const bottlenecks = sealLevel < 4
  ? objectives.filter(o => (o.seal_level as number) === sealLevel)
  : [];

const strengths = objectives.filter(o => (o.seal_level as number) >= 3);
const weaknesses = objectives.filter(o => (o.seal_level as number) <= 1 ||
  ((o.seal_level as number) === sealLevel && sealLevel < 4));

const SEAL_LABELS = ['No Sovereignty', 'Minimal Sovereignty', 'Partial Sovereignty', 'Substantial Sovereignty', 'Full Digital Sovereignty'];
const SEAL_COLORS = ['#dc2626', '#f97316', '#eab308', '#22c55e', '#16a34a'];
const levelPrefix = variant === 'Generalized' ? 'CSL' : 'SEAL';

// Top 5 priority improvements — look up question title from criteria
interface GapItem { objective_id: string; question_id: string; tier: string; priority: number }
const topImprovements = (gapReport as GapItem[]).slice(0, 5).map(g => {
  let title = g.question_id;
  let source = '';
  for (const obj of criteria.objectives) {
    const q = obj.questions.find(q => q.id === g.question_id);
    if (q) {
      title = (variant === 'Generalized' && q.title_generalized) ? q.title_generalized : q.title;
      if (q.type === 'single') source = q.source?.clause ?? '';
      else if (q.type === 'tiered') source = (g.tier === 'national' ? q.tiers.national?.source?.clause : q.tiers.bloc?.source?.clause) ?? '';
      break;
    }
  }
  return { ...g, title, source };
});
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assessment Result — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-semibold text-lg tracking-tight">Cloud Sovereignty Index</a>
    <div class="flex gap-3 items-center flex-wrap">
      <a href={`/assess/${id}/SOV-1`} class="text-sm px-3 py-1.5 border border-gray-200 rounded-lg hover:bg-gray-50 transition">Edit assessment</a>
      <button id="copy-url-btn" class="text-sm text-blue-600 hover:underline">Share result</button>
      {result && (
        <PdfExportButton
          client:load
          result={result}
          criteria={criteria}
          companyName={companyName}
          country={country}
        />
      )}
      <ExportAnswers
        client:load
        assessmentId={id!}
        criteria={criteria}
        result={result}
      />
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-8">
    {result ? (
      <>
        <ScoreHero
          client:load
          score={score}
          sealLevel={sealLevel}
          variant={variant}
          instrumentVersion={instrumentVersion}
          c5Supplementary={c5Supplementary}
        />

        {/* ── SEAL explanation ──────────────────────────────────────────────── */}
        <div class="mt-6 p-4 rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-700">
          {sealLevel === 4 ? (
            <p><span class="font-semibold text-green-700">All objectives meet the highest sovereignty threshold.</span> Your score of {Math.round(score)}% reflects full compliance across all criteria.</p>
          ) : (
            <>
              <p class="mb-2">
                Your score of <strong>{Math.round(score)}%</strong> reflects points earned across all criteria.
                Your {levelPrefix} level is capped at <strong style={`color: ${SEAL_COLORS[sealLevel]}`}>{levelPrefix} {sealLevel} — {SEAL_LABELS[sealLevel]}</strong> because
                the following {bottlenecks.length === 1 ? 'objective has' : 'objectives have'} not yet reached the next threshold:
                <strong> {bottlenecks.map(o => o.title as string).join(', ')}</strong>.
              </p>
              {topImprovements[0] && (
                <p class="text-gray-600">
                  Highest-priority action: answer <strong>{topImprovements[0].title}</strong> ({topImprovements[0].question_id}, {topImprovements[0].tier} tier).
                </p>
              )}
            </>
          )}
        </div>

        {/* ── Strengths ─────────────────────────────────────────────────────── */}
        {strengths.length > 0 && (
          <div class="mt-8">
            <h2 class="font-semibold text-base mb-3">Strengths</h2>
            <div class="space-y-2">
              {strengths.map(obj => {
                const seal = obj.seal_level as number;
                const pct = (obj.max_score as number) > 0 ? Math.round(((obj.raw_score as number) / (obj.max_score as number)) * 100) : 0;
                const color = SEAL_COLORS[seal];
                return (
                  <div class="flex items-center gap-3 p-3 rounded-lg border border-green-100 bg-green-50">
                    <div class="flex-1">
                      <span class="font-medium text-sm">{obj.title as string}</span>
                      <span class="text-xs text-gray-500 ml-2">{obj.objective_id as string}</span>
                    </div>
                    <span class="text-sm font-medium" style={`color: ${color}`}>{pct}%</span>
                    <span class="text-xs px-2 py-0.5 rounded-full text-white font-medium" style={`background-color: ${color}`}>{levelPrefix} {seal}</span>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* ── Weaknesses ────────────────────────────────────────────────────── */}
        {weaknesses.length > 0 && (
          <div class="mt-8">
            <h2 class="font-semibold text-base mb-3">Weaknesses &amp; Limiting Factors</h2>
            <div class="space-y-2">
              {weaknesses.map(obj => {
                const seal = obj.seal_level as number;
                const pct = (obj.max_score as number) > 0 ? Math.round(((obj.raw_score as number) / (obj.max_score as number)) * 100) : 0;
                const color = SEAL_COLORS[seal];
                const isBottleneck = bottlenecks.some(b => b.objective_id === obj.objective_id);
                const topGap = gapReport.find(g => (g as GapItem).objective_id === obj.objective_id) as GapItem | undefined;
                let topGapTitle = topGap?.question_id;
                if (topGap) {
                  for (const o of criteria.objectives) {
                    const q = o.questions.find(q => q.id === topGap.question_id);
                    if (q) { topGapTitle = (variant === 'Generalized' && q.title_generalized) ? q.title_generalized : q.title; break; }
                  }
                }
                return (
                  <div class="p-3 rounded-lg border border-red-100 bg-red-50">
                    <div class="flex items-center gap-3 mb-1">
                      <div class="flex-1">
                        <span class="font-medium text-sm">{obj.title as string}</span>
                        <span class="text-xs text-gray-500 ml-2">{obj.objective_id as string}</span>
                        {isBottleneck && <span class="ml-2 text-xs bg-red-200 text-red-800 px-1.5 py-0.5 rounded font-medium">Limiting SEAL</span>}
                      </div>
                      <span class="text-sm font-medium" style={`color: ${color}`}>{pct}%</span>
                      <span class="text-xs px-2 py-0.5 rounded-full text-white font-medium" style={`background-color: ${color}`}>{levelPrefix} {seal}</span>
                    </div>
                    {topGapTitle && (
                      <p class="text-xs text-gray-600">Top gap: {topGapTitle} ({topGap?.question_id})</p>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* ── Priority improvements ─────────────────────────────────────────── */}
        {topImprovements.length > 0 && (
          <div class="mt-8">
            <h2 class="font-semibold text-base mb-3">Priority Improvement Areas</h2>
            <div class="space-y-2">
              {topImprovements.map((item, i) => (
                <a href={`#obj-${item.objective_id}`} class="block p-3 rounded-lg border border-amber-100 bg-amber-50 hover:bg-amber-100 transition group">
                  <div class="flex items-start gap-3">
                    <div class="text-xs font-bold text-amber-600 mt-0.5 w-5 shrink-0">#{i + 1}</div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium group-hover:underline">{item.title}</p>
                      <p class="text-xs text-gray-500 mt-0.5">{item.question_id} · {item.tier} tier{item.source ? ` · ${item.source}` : ''}</p>
                    </div>
                    <span class="text-xs text-amber-600 shrink-0 mt-0.5">↓ view details</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        {/* ── Results by objective (accordion) ─────────────────────────────── */}
        <div class="mt-8">
          <h2 class="font-semibold text-base mb-4">Results by objective</h2>
          <ObjectiveAccordion
            client:load
            objectives={objectives as Parameters<typeof ObjectiveAccordion>[0]['objectives']}
            criteria={criteria}
            country={country}
            variant={variant as 'EU-CSF' | 'Generalized'}
            overallSeal={sealLevel}
          />
        </div>

        {/* ── Submission history ───────────────────────────────────────────── */}
        {history.length > 0 && (
          <div class="mt-8">
            <h2 class="font-semibold text-base mb-3">Submission history</h2>
            <div class="border border-gray-100 rounded-lg overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 text-gray-500 text-left">
                    <th class="px-4 py-2 font-medium">#</th>
                    <th class="px-4 py-2 font-medium">Date</th>
                    <th class="px-4 py-2 font-medium">Score</th>
                    <th class="px-4 py-2 font-medium">{levelPrefix}</th>
                  </tr>
                </thead>
                <tbody>
                  {history.map((entry, i) => {
                    const isCurrent = i === 0;
                    const color = SEAL_COLORS[entry.seal_level] ?? '#6b7280';
                    const date = new Date(entry.submitted_at).toLocaleString('en-GB', {
                      day: 'numeric', month: 'short', year: 'numeric',
                      hour: '2-digit', minute: '2-digit'
                    });
                    return (
                      <tr class={`border-t border-gray-100 ${isCurrent ? 'bg-blue-50' : ''}`}>
                        <td class="px-4 py-2 text-gray-500 font-mono">
                          {history.length - i}
                          {isCurrent && <span class="ml-2 text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded font-medium">current</span>}
                        </td>
                        <td class="px-4 py-2 text-gray-700">{date}</td>
                        <td class="px-4 py-2 font-medium" style={`color: ${color}`}>{Math.round(entry.overall_score)}%</td>
                        <td class="px-4 py-2">
                          <span class="text-xs px-2 py-0.5 rounded-full text-white font-medium" style={`background-color: ${color}`}>
                            {levelPrefix} {entry.seal_level}
                          </span>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <div class="mt-8 p-4 bg-gray-50 rounded-xl text-sm text-gray-600">
          <p class="font-medium text-gray-900 mb-1">Methodological note</p>
          <p>
            This is a self-assessment, not a certification. Results are indicative based on your responses.
            All criteria sourced from BSI C5:2026 and EU Cloud Sovereignty Framework v1.2.1.
          </p>
        </div>
      </>
    ) : (
      <div class="py-20 text-center text-gray-400">
        {record ? 'Assessment not yet submitted.' : 'Assessment not found.'}
        {record && (
          <a href={`/assess/${id}/review`} class="block mt-4 text-blue-600 underline">
            Go to review page
          </a>
        )}
      </div>
    )}
  </main>

  <script define:vars={{ id }}>
    document.getElementById('copy-url-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const btn = document.getElementById('copy-url-btn');
        if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Share result'; }, 2000); }
      });
    });
  </script>
</body>
</html>
