---
import '../../../styles/global.css';
import ScoreHero from '../../../components/ScoreHero';
import ExportAnswers from '../../../components/ExportAnswers';
import ObjectiveAccordion from '../../../components/ObjectiveAccordion';
import C3aObjectiveAccordion from '../../../components/C3aObjectiveAccordion';
import PdfExportButton from '../../../components/PdfExportButton';
import { ControlMatrixReport } from '../../../components/ControlMatrixReport';
import DomainRadar from '../../../components/DomainRadar';
import ActionTracks from '../../../components/ActionTracks';
import type { ActionItem } from '../../../components/ActionTracks';
import criteriaJson from '../../../../data/criteria.json';
import countriesJson from '../../../../data/countries.json';
import type { CriteriaFile, ControlProfile, Question } from '../../../../shared/src/schema';
import type { AssessmentResult, EuCsfObjectiveResult, CsiObjectiveResult, C3aResult, CadaResult, AnswerMap } from '../../../../shared/src/types';
import { buildReport } from '../../../../shared/src/report';
import { displayTitle } from '../../../../shared/src/tier-resolution';
import { actionOwnerForQuestion, actionOwnerForClause, ACTION_OWNER_LABEL, type ActionOwner } from '../../../../shared/src/action-owner';
export const prerender = false;

const criteria = criteriaJson as unknown as CriteriaFile;

const { id } = Astro.params;

let record: Record<string, unknown> | null = null;
let result: AssessmentResult | null = null;

const apiBase = new URL('/api', Astro.request.url).toString();
try {
  const res = await fetch(`${apiBase}/assessments/${id}`);
  if (res.ok) {
    record = await res.json() as Record<string, unknown>;
    if (record.computed_score) {
      const raw = typeof record.computed_score === 'string'
        ? JSON.parse(record.computed_score as string)
        : record.computed_score;
      // v2.0 results have selected_frameworks; treat older results as csi_composite
      if (raw.selected_frameworks) {
        result = raw as AssessmentResult;
      } else if (raw.objectives) {
        // Legacy v1.x result — wrap in csi_composite key
        result = {
          assessment_id: id!,
          instrument_version: raw.instrument_version ?? '1.0',
          selected_frameworks: ['csi_composite'],
          variant: (record.variant as string) ?? 'EU-CSF',
          scope_ids: [],
          role: 'customer',
          assessed_at: (record?.finalized_at as string | null) ?? raw.finalized_at ?? '',
          csi_composite: {
            per_objective: Object.fromEntries(
              (raw.objectives as Array<Record<string, unknown>>).map((o: Record<string, unknown>) => [
                o.objective_id,
                {
                  objective_id: o.objective_id as string,
                  title: o.title as string,
                  weight: 0,
                  csl: (o.seal_level as number) ?? 0,
                  raw_score: o.raw_score as number,
                  max_score: o.max_score as number,
                  pct: (o.max_score as number) > 0 ? ((o.raw_score as number) / (o.max_score as number)) * 100 : 0,
                  questions: o.questions as CsiObjectiveResult['questions'],
                },
              ])
            ),
            global: { csl: raw.seal_level as number ?? 0, pct: raw.overall_score as number ?? 0 },
            gap_report: (raw.gap_report as AssessmentResult['csi_composite']['gap_report']) ?? [],
          },
        } as AssessmentResult;
      }
    }
  }
} catch {
  // Workers not available
}

// ── Control-matrix report ────────────────────────────────────────────────────
const rawControlProfile = record?.control_profile
  ? (typeof record.control_profile === 'string' ? JSON.parse(record.control_profile as string) : record.control_profile)
  : null;
const rawAnswers = record?.answers
  ? (typeof record.answers === 'string' ? JSON.parse(record.answers as string) : record.answers)
  : {};
const controlMatrixRows = rawControlProfile
  ? buildReport(rawControlProfile as ControlProfile, rawAnswers as AnswerMap)
  : [];

const variant = (record?.variant as string) ?? 'EU-CSF';
const instrumentVersion = (record?.instrument_version as string) ?? '2.0';
const isCsiLmic = (result?.selected_frameworks ?? []).includes('csi_composite');
const secondaryScore = result?.csi_composite
  ? {
      label: 'CSI Composite',
      value: `${Math.round(result.csi_composite.global.pct)}%`,
      detail: `CSL ${result.csi_composite.global.csl}`,
    }
  : undefined;
const companyName = (record?.company_name as string | undefined) || undefined;
const countryCode = (record?.national_country as string | undefined) || undefined;
// EU-CSF uses SEAL; a CSI-only assessment uses CSL (CSI never says "SEAL").
const levelPrefix = result?.eu_csf ? 'SEAL' : 'CSL';

const rawDate = (record?.finalized_at as string | null) ?? result?.assessed_at ?? null;
const assessedAt = rawDate
  ? new Date(rawDate).toLocaleString('en-GB', {
      day: 'numeric', month: 'long', year: 'numeric',
      hour: '2-digit', minute: '2-digit', timeZoneName: 'short',
    })
  : null;

const allCountries = [...countriesJson.EU, ...countriesJson.EEA_non_EU, ...countriesJson.non_EU];
const country = countryCode ? allCountries.find(c => c.code === countryCode) : undefined;

interface HistoryEntry { id: number; submitted_at: string; seal_level: number; overall_score: number }
const history = (record?.history as HistoryEntry[]) ?? [];

const SEAL_COLORS = ['#dc2626', '#f97316', '#eab308', '#22c55e', '#16a34a'];

// ── EU-CSF analysis helpers ──────────────────────────────────────────────────
const euCsfObjectives = result?.eu_csf
  ? Object.values(result.eu_csf.per_objective)
  : [];
const euCsfSeal = result?.eu_csf?.global.seal ?? 0;
const euCsfGaps = result?.eu_csf?.gap_report ?? [];

// ── CSI Composite analysis helpers ──────────────────────────────────────────
const csiObjectives = result?.csi_composite
  ? Object.values(result.csi_composite.per_objective)
  : [];
const csiCsl = result?.csi_composite?.global.csl ?? 0;
const csiWeakestCsl = result?.csi_composite?.global.weakest_link_csl ?? 0;
const csiGatingIds = result?.csi_composite?.global.gating_objective_ids ?? [];
const csiGaps = result?.csi_composite?.gap_report ?? [];
// Blocking objectives: the weakest-link domains that gate the assurance tier, plus any other
// sovereignty domain at CSL ≤ 1 — excluding SOV-8 (ESG, non-gating). These are what to fix.
const csiBlockers = csiObjectives
  .filter(o => o.objective_id !== 'SOV-8' && o.objective_id !== 'SOV-9' && o.max_score > 0)
  .filter(o => csiGatingIds.includes(o.objective_id) || o.csl <= 1)
  .sort((a, b) => a.csl - b.csl)
  .map(o => {
    const topGap = (csiGaps as Array<{ objective_id: string; question_id: string }>).find(g => g.objective_id === o.objective_id);
    return { ...o, topGap, gating: csiGatingIds.includes(o.objective_id) };
  });

// ── Action ownership (supplier-management vs internal-improvement) ────────────
// Single source: shared/src/action-owner.ts. Used for the two-track "What to do next"
// summary and the owner pills throughout the report.
const questionById = new Map<string, Question>();
for (const o of criteria.objectives) for (const q of o.questions) questionById.set(q.id, q);
const ownerForQuestionId = (qid?: string): ActionOwner =>
  qid && questionById.has(qid)
    ? actionOwnerForQuestion(questionById.get(qid)!, rawControlProfile as ControlProfile | null)
    : 'supplier';

const OWNER_PILL: Record<ActionOwner, { label: string; cls: string }> = {
  supplier: { label: ACTION_OWNER_LABEL.supplier, cls: 'bg-indigo-100 text-indigo-700' },
  internal: { label: ACTION_OWNER_LABEL.internal, cls: 'bg-emerald-100 text-emerald-700' },
};
const LAYER_NAMES: Record<string, string> = {
  L1: 'Facility', L2: 'Hardware', L3: 'Virtualization', L4: 'Managed/PaaS', L5: 'Operations', L6: 'Consumption',
};
function clauseLabel(text: string): string {
  const first = text.split('. ')[0];
  return first.length > 120 ? `${first.slice(0, 117)}…` : first;
}
// Procurement-clause templates from the control matrix, deduped across layers.
const clauseItems: ActionItem[] = (() => {
  const seen = new Set<string>();
  const out: ActionItem[] = [];
  for (const row of controlMatrixRows) {
    for (const c of row.bridges as Array<{ id: string; clause_text: string; realism_tag?: string }>) {
      if (seen.has(c.id)) continue;
      seen.add(c.id);
      out.push({
        id: c.id, label: clauseLabel(c.clause_text), owner: actionOwnerForClause(c),
        kind: 'clause', layer: `${row.layer} · ${LAYER_NAMES[row.layer] ?? row.layer}`,
      });
    }
  }
  return out;
})();

// CSI "what to do next": the blocking objectives (as gaps, classified by owner) + the
// recommended clause templates — split into the two tracks by the component.
const csiActionItems: ActionItem[] = result?.csi_composite
  ? [
      ...clauseItems,
      ...csiBlockers.map((b): ActionItem => ({
        id: b.topGap?.question_id ?? b.objective_id,
        label: b.title,
        detail: b.topGap ? resolveGapTitle(b.topGap as GapItem) : undefined,
        owner: ownerForQuestionId(b.topGap?.question_id),
        kind: 'gap', severity: b.csl,
      })),
    ]
  : [];

// Layer grouping for CSI Composite
const CSI_LAYERS = [
  { id: 'sovereignty', label: 'Sovereignty', description: 'Who ultimately controls the system', objectives: ['SOV-1', 'SOV-2'] },
  { id: 'resilience', label: 'Resilience', description: 'Can it survive disruption', objectives: ['SOV-3', 'SOV-4', 'SOV-5'] },
  { id: 'operational_viability', label: 'Operational Viability', description: 'Can it realistically operate locally', objectives: ['SOV-6', 'SOV-7', 'SOV-8'] },
] as const;

// ── C3A failed criteria ──────────────────────────────────────────────────────
const c3aFailedCriteria = result?.c3a?.failed_criteria ?? [];
const c3aLayerAFailures = c3aFailedCriteria.filter(f => f.tier === 'criterion' && ['SOV-2-01','SOV-2-02','SOV-2-03','SOV-3-01','SOV-4-09','SOV-4-10'].includes(f.question_id));
const c3aOtherFailures = c3aFailedCriteria.filter(f => !c3aLayerAFailures.includes(f));

// Top improvement for EU-CSF
interface GapItem { objective_id: string; question_id: string; tier: string; gap_score: number; seal_contribution?: number }
function resolveGapTitle(gap: GapItem): string {
  for (const obj of criteria.objectives) {
    const q = obj.questions.find(q => q.id === gap.question_id);
    if (q) return displayTitle(q, variant as 'EU-CSF' | 'Generalized');
  }
  return gap.question_id;
}

// ── CADA analysis helpers ────────────────────────────────────────────────────
const cadaResult = result?.cada as CadaResult | undefined;
const UAL_COLORS_RESULT = ['#dc2626', '#f97316', '#eab308', '#22c55e', '#16a34a'];
const UAL_NAMES_RESULT = ['Not Attained', 'Level 1 — Self-Assessment', 'Level 2 — Third-Party Audited', 'Level 3 — Enhanced', 'Level 4 — Highest Assurance'];

// Build per-level CADA criterion breakdown for the detailed view
const cadaCriteriaByLevel = cadaResult ? (() => {
  const allCadaQs = criteria.objectives.flatMap(obj =>
    obj.questions
      .filter(q => (q as any).applies_to_cada)
      .map(q => ({
        id: q.id,
        title: q.title,
        objective_id: obj.id,
        min_level: Math.min(...((q as any).cada_assurance_level ?? [99])),
        annex_ref: (q as any).cada_annex_ref ?? '',
        supplementary: q.supplementary_info ?? '',
      }))
  );
  return cadaResult.levels.map(lvl => {
    const failSet = new Set(lvl.failing_criteria.map(f => f.question_id));
    const applicable = allCadaQs.filter(q => q.min_level <= lvl.level);
    return {
      level: lvl.level,
      label: lvl.label,
      gate_passed: lvl.gate_passed,
      criteria_passed: lvl.criteria_passed,
      criteria_total: lvl.criteria_total,
      criteria: applicable.map(q => ({ ...q, passed: !failSet.has(q.id) })),
    };
  });
})() : [];

const euCsfAllGaps = (euCsfGaps as GapItem[]).slice(0, 8).map(g => ({ ...g, title: resolveGapTitle(g) }));
// Sovereignty blockers: failing criteria that gate SEAL advancement (seal_contribution ≤ euCsfSeal + 1)
const euCsfBlockers = euCsfAllGaps.filter(g => g.seal_contribution != null && g.seal_contribution > 0 && g.seal_contribution <= euCsfSeal + 1);
const euCsfMaturityGaps = euCsfAllGaps.filter(g => !euCsfBlockers.includes(g)).slice(0, 5);

// Domain maturity radar: one axis per sovereignty domain SOV-1…SOV-8 (each axis = that
// domain's CSL). Excludes non-domain / weight-0 objectives. answered = had scoreable answers.
const radarDomains = csiObjectives
  .filter(o => /^SOV-[1-8]$/.test(o.objective_id))
  .sort((a, b) => a.objective_id.localeCompare(b.objective_id))
  .map(o => ({ id: o.objective_id, title: o.title, csl: o.csl, answered: o.max_score > 0 }));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assessment Result — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-semibold text-lg tracking-tight">Cloud Sovereignty Index</a>
    <div class="flex gap-3 items-center flex-wrap">
      <a href={`/assess/${id}/SOV-1`} class="text-sm px-3 py-1.5 border border-gray-200 rounded-lg hover:bg-gray-50 transition">Edit assessment</a>
      <button id="copy-url-btn" class="text-sm text-blue-600 hover:underline">Share result</button>
      {result && (
        <PdfExportButton
          client:load
          result={result as Record<string, unknown>}
          criteria={criteria}
          companyName={companyName}
          country={country}
          controlProfile={rawControlProfile}
        />
      )}
      <ExportAnswers
        client:load
        assessmentId={id!}
        criteria={criteria}
        result={result as unknown as Record<string, unknown>}
        variant={variant as 'EU-CSF' | 'Generalized'}
      />
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-6 py-8">
    {result ? (
      <>
        <ScoreHero client:load result={result} />

        {assessedAt && (
          <p class="text-xs text-gray-400 text-center -mt-3 mb-4">
            Submitted {assessedAt}
          </p>
        )}

        {/* ── Control-matrix posture report ─────────────────────────────────── */}
        {isCsiLmic && controlMatrixRows.length > 0 && (
          <section class="mt-8">
            <h2 class="font-semibold text-base mb-1">
              Layered control posture
              <span class="text-xs font-normal text-gray-400 ml-2">posture-first — framework scores below</span>
            </h2>
            <p class="text-sm text-gray-500 mb-4">
              Each infrastructure layer is mapped across two independent channels: who holds control
              and how well it is managed. Expand a layer to see triggered risks and procurement bridges.
            </p>
            <ControlMatrixReport client:load rows={controlMatrixRows} secondaryScore={secondaryScore} />
          </section>
        )}

        {/* ── EU-CSF section ────────────────────────────────────────────────── */}
        {result.eu_csf && (
          <section class="mt-8">
            <h2 class="font-semibold text-base mb-3 flex items-center gap-2">
              EU Cloud Sovereignty Framework
              <span class="text-xs font-normal text-gray-400">EU-CSF v1.2.1</span>
            </h2>

            {euCsfBlockers.length > 0 && (
              <div class="mb-4">
                <h3 class="text-sm font-semibold text-red-700 mb-2">Sovereignty blockers</h3>
                <div class="space-y-1.5">
                  {euCsfBlockers.map((item, i) => (
                    <div class="flex items-start gap-3 p-3 rounded-lg border border-red-100 bg-red-50">
                      <div class="text-xs font-bold text-red-500 mt-0.5 w-5 shrink-0">#{i + 1}</div>
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium">{item.title}</p>
                        <p class="text-xs text-gray-500 mt-0.5 flex items-center gap-1.5 flex-wrap">
                          <span class={`text-[10px] font-semibold px-1.5 py-0.5 rounded ${OWNER_PILL[ownerForQuestionId(item.question_id)].cls}`}>{OWNER_PILL[ownerForQuestionId(item.question_id)].label}</span>
                          {item.question_id} · {item.tier} tier
                        </p>
                      </div>
                      {item.seal_contribution != null && (
                        <div class="text-xs font-semibold px-2 py-0.5 rounded-full text-white shrink-0 self-start mt-0.5"
                          style={`background-color: ${SEAL_COLORS[item.seal_contribution] ?? '#6b7280'}`}>
                          SEAL {item.seal_contribution}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}
            {euCsfMaturityGaps.length > 0 && (
              <div class="mb-4">
                <h3 class="text-sm font-medium text-gray-700 mb-2">Sovereignty maturity improvements</h3>
                <div class="space-y-1.5">
                  {euCsfMaturityGaps.map((item, i) => (
                    <div class="flex items-start gap-3 p-3 rounded-lg border border-amber-100 bg-amber-50">
                      <div class="text-xs font-bold text-amber-600 mt-0.5 w-5 shrink-0">#{i + 1}</div>
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium">{item.title}</p>
                        <p class="text-xs text-gray-500 mt-0.5 flex items-center gap-1.5 flex-wrap">
                          <span class={`text-[10px] font-semibold px-1.5 py-0.5 rounded ${OWNER_PILL[ownerForQuestionId(item.question_id)].cls}`}>{OWNER_PILL[ownerForQuestionId(item.question_id)].label}</span>
                          {item.question_id} · {item.tier} tier
                        </p>
                      </div>
                      {item.seal_contribution != null && (
                        <div class="text-xs font-semibold px-2 py-0.5 rounded-full text-white shrink-0 self-start mt-0.5"
                          style={`background-color: ${SEAL_COLORS[item.seal_contribution] ?? '#6b7280'}`}>
                          SEAL {item.seal_contribution}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}

            <ObjectiveAccordion
              client:load
              objectives={euCsfObjectives.map(o => ({
                objective_id: o.objective_id,
                title: o.title,
                seal_level: o.seal,
                raw_score: o.raw_score,
                max_score: o.max_score,
                questions: o.questions,
              }))}
              criteria={criteria}
              country={country}
              variant={variant as 'EU-CSF' | 'Generalized'}
              overallSeal={euCsfSeal}
              profile={rawControlProfile}
            />
          </section>
        )}

        {/* ── C3A section ───────────────────────────────────────────────────── */}
        {result.c3a && (
          <section class="mt-8">
            <h2 class="font-semibold text-base mb-3 flex items-center gap-2">
              BSI C3A — Criteria enabling Cloud Computing Autonomy
              <span class="text-xs font-normal text-gray-400">C3A v1.0</span>
            </h2>

            {result.c3a.layer_a_blocked && c3aLayerAFailures.length > 0 && (
              <div class="mb-3 p-3 rounded-xl border border-red-200 bg-red-50 text-sm">
                <p class="font-semibold text-red-800 mb-1">Sovereignty Failure — Layer A prerequisites not met</p>
                <p class="text-xs text-red-700 mb-2">Critical autonomy prerequisites remain externally dependent. Autonomy attainment is blocked until all Layer A criteria are met.</p>
                <div class="flex flex-wrap gap-1.5">
                  {c3aLayerAFailures.map(f => (
                    <span class="text-xs font-mono bg-red-100 text-red-800 px-1.5 py-0.5 rounded">{f.question_id}</span>
                  ))}
                </div>
              </div>
            )}
            {c3aOtherFailures.filter(f => f.tier === 'criterion').length > 0 && (
              <div class="mb-4 p-3 rounded-xl border border-orange-100 bg-orange-50 text-sm text-gray-700">
                <p class="font-medium text-orange-700 mb-1">
                  {c3aOtherFailures.filter(f => f.tier === 'criterion').length} other criterion/criteria not met
                </p>
                <p class="text-xs text-gray-500">Expand each objective below to see per-question detail.</p>
              </div>
            )}

            <C3aObjectiveAccordion
              client:load
              c3a={result.c3a as C3aResult}
              criteria={criteria}
            />
          </section>
        )}

        {/* ── CSI Composite section ─────────────────────────────────────────── */}
        {result.csi_composite && (
          <section class="mt-8">
            <h2 class="font-semibold text-base mb-3 flex items-center gap-2">
              CSI — Operational Sovereignty & Resilience Assessment
              <span class="text-xs font-normal text-gray-400 bg-blue-100 text-blue-600 px-1.5 py-0.5 rounded">editorial framework</span>
            </h2>

            {/* Assurance gate — which domains hold the headline tier (one line; detail is in the tracks/accordions) */}
            {csiBlockers.length > 0 && (
              <p class="mb-4 text-sm text-amber-800 bg-amber-50 border border-amber-200 rounded-lg px-3 py-2">
                <span class="font-semibold">Assurance gate (CSL {csiCsl}):</span>{' '}
                held by <strong>{csiBlockers.filter(b => b.gating).map(b => b.objective_id).join(', ') || csiBlockers.map(b => b.objective_id).join(', ')}</strong>.
                A high coverage % cannot offset a blocking domain — raise the lowest domain(s) to lift the tier.
              </p>
            )}

            {/* What to do next — supplier vs internal */}
            <ActionTracks items={csiActionItems} levelLabel="CSL" />

            {/* Domain maturity radar */}
            {radarDomains.length >= 3 && (
              <div class="mb-6">
                <h3 class="text-sm font-semibold text-gray-800 mb-2">Domain maturity <span class="text-xs font-normal text-gray-400">CSL per domain (assurance, not %)</span></h3>
                <DomainRadar client:load domains={radarDomains} globalCsl={result.csi_composite.global.csl} maxCsl={4} />
              </div>
            )}

            {/* Layered objective groups */}
            {CSI_LAYERS.map(layer => {
              const layerObjs = csiObjectives.filter(o => layer.objectives.includes(o.objective_id as any));
              if (layerObjs.length === 0) return null;
              const isEnvLayer = layer.id === 'operational_viability';
              return (
                <div class="mb-6">
                  <div class="flex items-center gap-2 mb-2">
                    <h3 class="text-sm font-semibold text-gray-800">{layer.label}</h3>
                    <span class="text-xs text-gray-400">{layer.description}</span>
                  </div>
                  {isEnvLayer && (
                    <p class="text-xs text-gray-400 italic mb-2">
                      Note: SOV-8 Environmental Sustainability is an ESG/policy dimension and does not affect sovereignty attainment.
                    </p>
                  )}
                  <ObjectiveAccordion
                    client:load
                    objectives={layerObjs.map(o => ({
                      objective_id: o.objective_id,
                      title: o.title,
                      seal_level: o.csl,
                      raw_score: o.raw_score,
                      max_score: o.max_score,
                      questions: o.questions,
                    }))}
                    criteria={criteria}
                    country={country}
                    variant={variant as 'EU-CSF' | 'Generalized'}
                    overallSeal={csiCsl}
                    levelLabel="CSL"
                    profile={rawControlProfile}
                  />
                </div>
              );
            })}
          </section>
        )}

        {/* ── CADA section ─────────────────────────────────────────────────── */}
        {cadaResult && (
          <section class="mt-8">
            <h2 class="font-semibold text-base mb-1 flex items-center gap-2">
              Cloud &amp; AI Development Act (CADA)
              <span class="text-xs font-normal text-gray-400">COM(2026) 502</span>
            </h2>
            <div class="mb-4 px-3 py-2 rounded-lg bg-amber-50 border border-amber-200 text-xs text-amber-800">
              Proposed EU Regulation — not yet adopted law. Results are indicative only and carry no legal status.
            </div>

            {/* Global result callout */}
            <div class="mb-4 p-4 rounded-xl border" style={`border-color: ${UAL_COLORS_RESULT[cadaResult.highest_level_achieved]}40; background-color: ${UAL_COLORS_RESULT[cadaResult.highest_level_achieved]}0a`}>
              <div class="flex items-center gap-3 flex-wrap">
                <span class="px-3 py-1.5 rounded-lg text-sm font-bold text-white" style={`background-color: ${UAL_COLORS_RESULT[cadaResult.highest_level_achieved]}`}>
                  UAL {cadaResult.highest_level_achieved} — {UAL_NAMES_RESULT[cadaResult.highest_level_achieved]}
                </span>
                {cadaResult.audit_required && (
                  <span class="text-xs text-purple-700 bg-purple-50 border border-purple-200 rounded px-2 py-1">
                    Independent audit required for formal recognition (Art. 20)
                  </span>
                )}
              </div>
              {cadaResult.highest_level_achieved === 4 && (
                <p class="text-sm text-green-700 mt-2 font-medium">All CADA Annex II criteria met. Seek third-party audit for formal UAL 4 recognition.</p>
              )}
            </div>

            {/* Per-level criterion breakdown */}
            <div class="space-y-4 mb-4">
              {cadaCriteriaByLevel.map(lvl => (
                <div class="border border-gray-200 rounded-xl overflow-hidden">
                  <div class={`px-4 py-3 flex items-center justify-between ${lvl.gate_passed ? 'bg-green-50' : 'bg-red-50'}`}>
                    <div class="flex items-center gap-2">
                      <span class="font-bold text-xs px-2 py-0.5 rounded text-white" style={`background-color: ${UAL_COLORS_RESULT[lvl.level]}`}>
                        UAL {lvl.level}
                      </span>
                      <span class="text-xs text-gray-600 hidden sm:inline">{lvl.label}</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="text-xs tabular-nums text-gray-500">{lvl.criteria_passed}/{lvl.criteria_total} criteria</span>
                      {lvl.gate_passed
                        ? <span class="text-green-700 font-semibold text-xs">✓ Gate passed</span>
                        : <span class="text-red-600 font-semibold text-xs">✗ Gate not cleared</span>}
                    </div>
                  </div>
                  <div class="divide-y divide-gray-100">
                    {lvl.criteria.map(crit => (
                      <div class={`px-4 py-2.5 flex items-start gap-3 ${crit.passed ? '' : 'bg-red-50'}`}>
                        <span class={`text-sm font-bold mt-0.5 shrink-0 ${crit.passed ? 'text-green-600' : 'text-red-500'}`}>
                          {crit.passed ? '✓' : '✗'}
                        </span>
                        <div class="flex-1 min-w-0">
                          <p class={`text-sm ${crit.passed ? 'text-gray-700' : 'text-gray-900 font-medium'}`}>{crit.title}</p>
                          <p class="text-xs text-gray-400 mt-0.5">
                            <span class="font-mono">{crit.id}</span>
                            {crit.annex_ref && <span class="ml-2 text-purple-600">{crit.annex_ref}</span>}
                            <span class="ml-2 text-gray-400">{crit.objective_id}</span>
                          </p>
                          {!crit.passed && crit.supplementary && (
                            <p class="text-xs text-red-700 bg-red-50 rounded mt-1 px-2 py-1 leading-relaxed line-clamp-2">
                              {crit.supplementary.slice(0, 150)}{crit.supplementary.length > 150 ? '…' : ''}
                            </p>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            {/* Gap report: priority actions for next level */}
            {cadaResult.gap_report.length > 0 && cadaResult.highest_level_achieved < 4 && (
              <div class="mb-4">
                <h3 class="text-sm font-semibold mb-2 text-gray-700">
                  Priority actions to reach UAL {cadaResult.highest_level_achieved + 1}
                </h3>
                <div class="space-y-1.5">
                  {cadaResult.gap_report.map((item) => {
                    const q = criteria.objectives.flatMap(o => o.questions).find(q => q.id === item.question_id);
                    const annex = (q as any)?.cada_annex_ref ?? '';
                    const hint = q?.supplementary_info ?? '';
                    return (
                      <div class="flex items-start gap-3 p-3 rounded-lg border border-red-100 bg-red-50">
                        <div class="text-xs font-bold text-red-500 mt-0.5 w-5 shrink-0">#{item.priority}</div>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm font-medium">{item.title}</p>
                          <p class="text-xs text-gray-500 mt-0.5 flex items-center gap-1.5 flex-wrap">
                            <span class={`text-[10px] font-semibold px-1.5 py-0.5 rounded ${OWNER_PILL[ownerForQuestionId(item.question_id)].cls}`}>{OWNER_PILL[ownerForQuestionId(item.question_id)].label}</span>
                            {item.question_id}
                            {annex && <span class="font-mono text-purple-600">{annex}</span>}
                            <span>· Blocks UAL {item.blocks_level}</span>
                          </p>
                          {hint && (
                            <p class="text-xs text-red-700 mt-1 leading-relaxed">
                              {hint.slice(0, 180)}{hint.length > 180 ? '…' : ''}
                            </p>
                          )}
                        </div>
                        <span class="text-xs font-semibold px-2 py-0.5 rounded-full text-white shrink-0 self-start mt-0.5" style={`background-color: ${UAL_COLORS_RESULT[item.blocks_level]}`}>
                          UAL {item.blocks_level}
                        </span>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}
          </section>
        )}

        {/* ── Submission history ───────────────────────────────────────────── */}
        {history.length > 0 && (
          <div class="mt-8">
            <h2 class="font-semibold text-base mb-3">Submission history</h2>
            <div class="border border-gray-100 rounded-lg overflow-hidden">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 text-gray-500 text-left">
                    <th class="px-4 py-2 font-medium">#</th>
                    <th class="px-4 py-2 font-medium">Date</th>
                    <th class="px-4 py-2 font-medium">Score</th>
                    <th class="px-4 py-2 font-medium">{levelPrefix}</th>
                  </tr>
                </thead>
                <tbody>
                  {history.map((entry, i) => {
                    const isCurrent = i === 0;
                    const color = SEAL_COLORS[entry.seal_level] ?? '#6b7280';
                    const date = new Date(entry.submitted_at).toLocaleString('en-GB', {
                      day: 'numeric', month: 'short', year: 'numeric',
                      hour: '2-digit', minute: '2-digit'
                    });
                    return (
                      <tr class={`border-t border-gray-100 ${isCurrent ? 'bg-blue-50' : ''}`}>
                        <td class="px-4 py-2 text-gray-500 font-mono">
                          {history.length - i}
                          {isCurrent && <span class="ml-2 text-xs bg-blue-100 text-blue-700 px-1.5 py-0.5 rounded font-medium">current</span>}
                        </td>
                        <td class="px-4 py-2 text-gray-700">{date}</td>
                        <td class="px-4 py-2 font-medium" style={`color: ${color}`}>{Math.round(entry.overall_score)}%</td>
                        <td class="px-4 py-2">
                          <span class="text-xs px-2 py-0.5 rounded-full text-white font-medium" style={`background-color: ${color}`}>
                            {levelPrefix} {entry.seal_level}
                          </span>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <div class="mt-8 p-4 bg-gray-50 rounded-xl text-sm text-gray-600">
          <p class="font-medium text-gray-900 mb-1">Methodological note</p>
          <p>
            This is a self-assessment, not a certification. Scope: cloud sovereignty only.
            Security attestation (e.g. C5:2026, ISO 27001) is assumed and not assessed here.
            EU-CSF results follow EU Cloud Sovereignty Framework v1.2.1 (European Commission).
            C3A results follow BSI Criteria enabling Cloud Computing Autonomy v1.0.
            CSI Composite is an editorial framework and is not a source-standard certification.
          </p>
        </div>
      </>
    ) : (
      <div class="py-20 text-center text-gray-400">
        {record ? 'Assessment not yet submitted.' : 'Assessment not found.'}
        {record && (
          <a href={`/assess/${id}/review`} class="block mt-4 text-blue-600 underline">
            Go to review page
          </a>
        )}
      </div>
    )}
  </main>

  <script define:vars={{ id }}>
    document.getElementById('copy-url-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const btn = document.getElementById('copy-url-btn');
        if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Share result'; }, 2000); }
      });
    });
  </script>
</body>
</html>
