---
import '../../../styles/global.css';

const { id } = Astro.params;
const url = `${Astro.url.origin}/assess/${id}/SOV-1`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Assessment Created — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-4">
    <a href="/" class="font-semibold text-lg tracking-tight">Cloud Sovereignty Index</a>
  </header>

  <main class="max-w-xl mx-auto px-6 py-12">
    <div class="mb-8">
      <div class="text-green-600 font-semibold text-sm mb-2">Assessment created</div>
      <h1 class="text-2xl font-bold mb-4">Bookmark your assessment URL</h1>
      <p class="text-gray-600 text-sm mb-6">
        We don't collect emails, so we can't help you recover a lost link.
        Save the URL below — it's the only way to resume your assessment on another device.
      </p>

      <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 flex items-center gap-3 mb-2">
        <span id="url-display" class="text-sm font-mono text-gray-800 flex-1 break-all">{url}</span>
        <button id="copy-btn" class="text-sm font-medium text-blue-600 hover:text-blue-800 whitespace-nowrap">
          Copy URL
        </button>
      </div>
      <p class="text-xs text-gray-400">This URL expires after 12 months of inactivity.</p>
    </div>

    <a href={`/assess/${id}/SOV-1`}
      class="inline-block bg-gray-900 text-white rounded-lg px-6 py-2.5 text-sm font-medium hover:bg-gray-700 transition">
      Begin assessment →
    </a>
  </main>

  <script define:vars={{ url }}>
    document.getElementById('copy-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(url).then(() => {
        const btn = document.getElementById('copy-btn');
        if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy URL'; }, 2000); }
      });
    });
  </script>
</body>
</html>
