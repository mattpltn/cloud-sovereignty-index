---
import '../../../styles/global.css';
import ScopeFindings from '../../../components/ScopeFindings';
import AutoAnswers from '../../../components/AutoAnswers';
import criteriaJson from '../../../../data/criteria.json';
import type { CriteriaFile } from '../../../../shared/src/schema';
export const prerender = false;

const criteria = criteriaJson as unknown as CriteriaFile;
const { id } = Astro.params;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Review & Submit — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-4">
    <a href="/" class="font-semibold text-lg tracking-tight">Cloud Sovereignty Index</a>
  </header>

  <main class="max-w-xl mx-auto px-6 py-10">
    <h1 class="text-2xl font-bold mb-2">Review & submit</h1>
    <p class="text-gray-600 text-sm mb-8">
      Check your answers before submitting. You can go back and change any answer.
      Once submitted, the assessment is locked.
    </p>

    <div id="answer-summary" class="mb-8 text-sm text-gray-600">Loading answers…</div>

    <AutoAnswers client:load id={id} criteria={criteria} />

    <ScopeFindings client:load id={id} criteria={criteria} />

    <button id="submit-btn"
      class="w-full bg-gray-900 text-white rounded-lg px-4 py-2.5 text-sm font-medium hover:bg-gray-700 transition disabled:opacity-50 disabled:cursor-not-allowed">
      Submit assessment
    </button>

    <p id="error-msg" class="text-red-600 text-sm mt-3 hidden"></p>
  </main>

  <script define:vars={{ id }}>
    const cached = JSON.parse(localStorage.getItem(`csi:${id}`) ?? '{}');
    const answers = cached.answers ?? {};
    const count = Object.keys(answers).length;
    const summary = document.getElementById('answer-summary');
    if (summary) {
      summary.textContent = `${count} question${count !== 1 ? 's' : ''} answered.`;
    }

    const submitBtn = document.getElementById('submit-btn');
    const errorMsg = document.getElementById('error-msg');

    submitBtn?.addEventListener('click', async () => {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
      errorMsg.classList.add('hidden');

      try {
        const profileRaw = localStorage.getItem(`csi:${id}:profile`);
        const control_profile = profileRaw ? JSON.parse(profileRaw) : undefined;

        const patchBody = { answers, ...(control_profile ? { control_profile } : {}) };
        const patchRes = await fetch(`/api/assessments/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(patchBody),
        });
        if (!patchRes.ok) throw new Error('Failed to save answers');

        const res = await fetch(`/api/assessments/${id}/submit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ share_publicly: false }),
        });
        if (!res.ok) throw new Error('Submit failed');

        window.location.href = `/assess/${id}/result`;
      } catch (err) {
        errorMsg.textContent = String(err);
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit assessment';
      }
    });
  </script>
</body>
</html>
