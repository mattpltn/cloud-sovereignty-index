---
import '../../../styles/global.css';
import Questionnaire from '../../../components/Questionnaire';
import criteriaJson from '../../../../data/criteria.json';
import countriesJson from '../../../../data/countries.json';
import type { CriteriaFile } from '../../../../shared/src/schema';

export const prerender = false;

const criteria = criteriaJson as unknown as CriteriaFile;
const { id, objective } = Astro.params;

// Validate objective (full list used for redirect fallback before frameworks are known)
const allObjectiveIds = criteria.objectives.map(o => o.id);
if (!allObjectiveIds.includes(objective!)) {
  return Astro.redirect(`/assess/${id}/SOV-1`);
}

const obj = criteria.objectives.find(o => o.id === objective)!;

// Fetch assessment from API to get country/variant/frameworks
let variant: 'EU-CSF' | 'Generalized' = 'EU-CSF';
let countryCode: string | undefined;
let country;
let selectedFrameworks: string[] = ['csi_composite'];
let customerSelectedAcIds: string[] = [];
let selectedObjectives: string[] = [];

try {
  const apiBase = new URL('/api', Astro.request.url).toString();
  const res = await fetch(`${apiBase}/assessments/${id}`);
  if (res.ok) {
    const data = await res.json() as {
      variant: string;
      national_country?: string;
      selected_frameworks?: string;
      customer_selected_ac_ids?: string;
      selected_objectives?: string;
    };
    variant = data.variant as 'EU-CSF' | 'Generalized';
    countryCode = data.national_country ?? undefined;
    if (data.selected_frameworks) selectedFrameworks = JSON.parse(data.selected_frameworks);
    if (data.customer_selected_ac_ids) customerSelectedAcIds = JSON.parse(data.customer_selected_ac_ids);
    if (data.selected_objectives) selectedObjectives = JSON.parse(data.selected_objectives);
  }
} catch {
  // Workers not running — continue without country data
}

if (countryCode) {
  const all = [...countriesJson.EU, ...countriesJson.EEA_non_EU, ...countriesJson.non_EU];
  country = all.find(c => c.code === countryCode);
}

// Filter objectives to those with at least one visible question for the selected frameworks
const fw = new Set(selectedFrameworks);
const acIdSet = new Set(customerSelectedAcIds);
const objectiveIds = criteria.objectives
  .filter(o => o.questions.some(q => {
    if (q.c3a_tier === 'additional') return fw.has('c3a') && acIdSet.has(q.id);
    return (fw.has('eu_csf') && q.applies_to_eu_csf) ||
           (fw.has('c3a') && q.applies_to_c3a) ||
           (fw.has('csi_composite') && q.applies_to_csi_composite);
  }))
  .map(o => o.id);

// Further filter by user-selected domains (empty = all)
const domainIds = selectedObjectives.length > 0
  ? objectiveIds.filter(id => selectedObjectives.includes(id))
  : objectiveIds;
const finalObjectiveIds = domainIds.length > 0 ? domainIds : objectiveIds;

// Redirect to first valid objective if current one has no visible questions
if (!finalObjectiveIds.includes(objective!)) {
  return Astro.redirect(`/assess/${id}/${finalObjectiveIds[0] ?? 'SOV-1'}`);
}

const resumeUrl = Astro.url.href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{obj.title} ({obj.id}) — Cloud Sovereignty Index</title>
</head>
<body class="bg-white text-gray-900 min-h-screen">
  <header class="border-b border-gray-200 px-6 py-3 flex items-center justify-between gap-4">
    <a href="/" class="font-semibold text-base tracking-tight shrink-0">Cloud Sovereignty Index</a>
    <nav class="flex gap-1 text-xs text-gray-400 flex-wrap">
      {finalObjectiveIds.map(oid => (
        <a
          href={`/assess/${id}/${oid}`}
          class={`px-2 py-1 rounded font-mono ${oid === objective ? 'bg-gray-900 text-white' : 'hover:bg-gray-100'}`}
        >
          {oid}
        </a>
      ))}
    </nav>
  </header>

  {/* Resume banner */}
  <div class="bg-amber-50 border-b border-amber-100 px-6 py-2 flex items-center justify-between gap-4 text-xs text-amber-800">
    <span>Bookmark this page to resume your assessment later.</span>
    <div class="flex items-center gap-2 shrink-0">
      <a href={resumeUrl} id="url-display" class="font-mono text-amber-700 underline hidden sm:inline truncate max-w-xs">{resumeUrl}</a>
      <button id="copy-resume-btn" class="bg-amber-100 hover:bg-amber-200 border border-amber-300 text-amber-800 font-medium px-2.5 py-1 rounded-lg transition">
        Copy link
      </button>
    </div>
  </div>

  <main class="max-w-2xl mx-auto px-6 py-8">
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs font-mono bg-gray-100 text-gray-500 px-2 py-0.5 rounded">{obj.id}</span>
        <h1 class="text-xl font-bold">{obj.title}</h1>
      </div>
      <p class="text-sm text-gray-600">{obj.description}</p>
    </div>

    <Questionnaire
      client:load
      id={id!}
      objectiveId={objective!}
      criteria={criteria}
      country={country}
      variant={variant}
      allObjectiveIds={finalObjectiveIds}
      selectedFrameworks={selectedFrameworks}
      customerSelectedAcIds={customerSelectedAcIds}
    />
  </main>

  <script define:vars={{ resumeUrl }}>
    document.getElementById('copy-resume-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(resumeUrl).then(() => {
        const btn = document.getElementById('copy-resume-btn');
        if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy link'; }, 2000); }
      });
    });
  </script>
</body>
</html>
